{
  "info": {
    "name": "Sushrusa MVP - Payment Processing",
    "_postman_id": "p6c1e4b0-4d4e-4b2a-9e4a-4c4c4c4c4c4c",
    "description": "Payment Processing APIs for Sushrusa MVP. Includes endpoints for creating payments, processing transactions, managing payment methods, viewing payment history, and handling refunds.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Payment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"consultation_id\": \"{{consultation_id}}\",\n  \"patient_id\": \"{{patient_id}}\",\n  \"doctor_id\": \"{{doctor_id}}\",\n  \"amount\": 1500,\n  \"currency\": \"INR\",\n  \"payment_method\": \"card\",\n  \"description\": \"Consultation fee\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/payments",
          "host": ["{{base_url}}"],
          "path": ["api", "payments"]
        }
      },
      "response": []
    },
    {
      "name": "Get Payment by ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/api/payments/{{payment_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "payments", "{{payment_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Process Payment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payment_id\": \"{{payment_id}}\",\n  \"card_number\": \"4111111111111111\",\n  \"expiry_month\": \"12\",\n  \"expiry_year\": \"2025\",\n  \"cvv\": \"123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/payments/{{payment_id}}/process",
          "host": ["{{base_url}}"],
          "path": ["api", "payments", "{{payment_id}}", "process"]
        }
      },
      "response": []
    },
    {
      "name": "List Payments (Patient)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/api/patients/{{patient_id}}/payments",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", "{{patient_id}}", "payments"]
        }
      },
      "response": []
    },
    {
      "name": "List Payments (Doctor)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/api/doctors/{{doctor_id}}/payments",
          "host": ["{{base_url}}"],
          "path": ["api", "doctors", "{{doctor_id}}", "payments"]
        }
      },
      "response": []
    },
    {
      "name": "Add Payment Method",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"card\",\n  \"card_number\": \"4111111111111111\",\n  \"expiry_month\": \"12\",\n  \"expiry_year\": \"2025\",\n  \"card_holder_name\": \"John Doe\",\n  \"is_default\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/patients/{{patient_id}}/payment-methods",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", "{{patient_id}}", "payment-methods"]
        }
      },
      "response": []
    },
    {
      "name": "List Payment Methods",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/api/patients/{{patient_id}}/payment-methods",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", "{{patient_id}}", "payment-methods"]
        }
      },
      "response": []
    },
    {
      "name": "Remove Payment Method",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/api/patients/{{patient_id}}/payment-methods/{{payment_method_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", "{{patient_id}}", "payment-methods", "{{payment_method_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Request Refund",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payment_id\": \"{{payment_id}}\",\n  \"reason\": \"Consultation cancelled\",\n  \"amount\": 1500\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/payments/{{payment_id}}/refund",
          "host": ["{{base_url}}"],
          "path": ["api", "payments", "{{payment_id}}", "refund"]
        }
      },
      "response": []
    },
    {
      "name": "Get Payment Analytics",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/api/payments/analytics?start_date=2024-01-01&end_date=2024-12-31",
          "host": ["{{base_url}}"],
          "path": ["api", "payments", "analytics"],
          "query": [
            { "key": "start_date", "value": "2024-01-01" },
            { "key": "end_date", "value": "2024-12-31" }
          ]
        }
      },
      "response": []
    }
  ]
} 