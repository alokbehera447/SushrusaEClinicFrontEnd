{
  "info": {
    "name": "Sushrusa MVP - Consultation Management",
    "_postman_id": "c4c1e4b0-4d4e-4b2a-9e4a-4c4c4c4c4c4c",
    "description": "Consultation Management APIs for Sushrusa MVP. Includes endpoints for creating, retrieving, listing, updating, and canceling consultations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Consultation",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patient_id\": \"{{patient_id}}\",\n  \"doctor_id\": \"{{doctor_id}}\",\n  \"scheduled_time\": \"2024-06-01T10:00:00Z\",\n  \"reason\": \"General checkup\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/consultations",
          "host": ["{{base_url}}"],
          "path": ["api", "consultations"]
        }
      },
      "response": []
    },
    {
      "name": "Get Consultation by ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/api/consultations/{{consultation_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "consultations", "{{consultation_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "List Consultations (Patient)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/api/patients/{{patient_id}}/consultations",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", "{{patient_id}}", "consultations"]
        }
      },
      "response": []
    },
    {
      "name": "List Consultations (Doctor)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/api/doctors/{{doctor_id}}/consultations",
          "host": ["{{base_url}}"],
          "path": ["api", "doctors", "{{doctor_id}}", "consultations"]
        }
      },
      "response": []
    },
    {
      "name": "Update Consultation Status",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"completed\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/consultations/{{consultation_id}}/status",
          "host": ["{{base_url}}"],
          "path": ["api", "consultations", "{{consultation_id}}", "status"]
        }
      },
      "response": []
    },
    {
      "name": "Cancel Consultation",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{base_url}}/api/consultations/{{consultation_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "consultations", "{{consultation_id}}"]
        }
      },
      "response": []
    }
  ]
} 